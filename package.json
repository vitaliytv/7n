{
  "name": "mono",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "npm"
  ],
  "type": "module",
  "scripts": {
    "start": "bun ./npm/bin/n-7.js",
    "test": "vitest run",
    "lint": "bun run lint-ga && bun run lint-image && bun run lint-js && bun run lint-security && bun run lint-text && oxfmt .",
    "lint-ga": "n-cursor lint-ga",
    "lint-image": "npx @nitra/minify-image --src=. --write",
    "lint-js": "bunx oxlint --fix && bunx eslint --fix . && bunx jscpd . && bunx knip --no-config-hints",
    "lint-security": "trufflehog filesystem . --no-update --exclude-paths .trufflehog-exclude --results=verified,unknown --fail",
    "lint-text": "n-cursor lint-text",
    "oxfmt": "oxfmt .",
    "coverage": "n-cursor coverage"
  },
  "devDependencies": {
    "@nitra/cspell-dict": "^2.1.0",
    "@nitra/cursor": "^3.17.0",
    "@nitra/eslint-config": "^3.10.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=25"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
